<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Keychain's Keystore-encrypted DataStore is intentionally excluded. -->
        <include domain="database" path="." />
        <include domain="file" path="terminal-backgrounds/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="file" path="terminal-backgrounds/" />
    </device-transfer>
</data-extraction-rules>
