{
  "expo": {
    "name": "Whip",
    "slug": "whip",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "scheme": "whip",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Whip to attach photos you take to the remote terminal.",
          "photosPermission": "Allow Whip to attach selected photos to the remote terminal."
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": ["en", "zh-Hant"]
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "io.github.kaminarios.whip"
    },
    "android": {
      "allowBackup": true,
      "package": "io.github.kaminarios.whip"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "abffa698-56c9-41c1-9b61-3312006a895d"
      }
    },
    "owner": "kant64"
  }
}
